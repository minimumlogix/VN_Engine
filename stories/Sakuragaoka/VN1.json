  "storyDialogue": [
  {
    "chapter": 0,
    "scene": 1,
    "character": "NARRATION:neutral",
    "text": "[flash] Welcome {{user}} to <b>Sakuragaoka College</b>, where new beginnings tend to get a little messy.",
    "SpriteEffects": "Scanlines"
  },
  {
    "chapter": 0,
    "scene": 2,
    "character": "NARRATION:neutral",
    "text": "Cherry blossoms drift as students settle in, chasing dreams, escaping pasts, or just hoping to survive."
  },
  {
    "chapter": 0,
    "scene": 3,
    "character": "NARRATION:neutral",
    "text": "Among them, <span style=\"color:#ff66cc\">Takamoto Hoshi</span> sits restless, pink hair bright, already hunting for something fun."
  },
  {
    "chapter": 0,
    "scene": 4,
    "character": "NARRATION:neutral",
    "text": "Not far, <span style=\"color:#cccccc\">Kuwahara Hajime</span> folds into himself, a giant trying, and failing, to disappear."
  },
  {
    "chapter": 0,
    "scene": 5,
    "character": "NARRATION:neutral",
    "text": "Leaning back, <span style=\"color:#99ccff\">Nishimura Ryuu</span> watches the crowd like it’s a game he’s already solved."
  },
  {
    "chapter": 0,
    "scene": 6,
    "character": "NARRATION:neutral",
    "text": "Beside you, <span style=\"color:#ffffff\">Azuma Megumi</span> sits rigid, clutching her notebook like a lifeline."
  },
  {
    "chapter": 0,
    "scene": 7,
    "character": "NARRATION:neutral",
    "text": "The ceremony hums on, but something subtle shifts, like invisible threads pulling the wrong people together."
  },
  {
    "chapter": 0,
    "scene": 8,
    "character": "NARRATION:neutral",
    "text": "This moment feels ordinary. It won’t stay that way."
  },

  {
    "chapter": 1,
    "scene": 1,
    "character": "NARRATION:neutral",
    "text": "After the ceremony, the halls flood with noise, confusion, and first impressions no one rehearsed."
  },
  {
    "chapter": 1,
    "scene": 2,
    "character": "HOSHI:chaotic",
    "text": "Okay, seriously, is this place a maze or am I just speedrunning getting lost?"
  },
  {
    "chapter": 1,
    "scene": 3,
    "character": "HAJIME:defensive",
    "text": "I, I’ve looped this hallway three times… sorry if I’m in the way."
  },
  {
    "chapter": 1,
    "scene": 4,
    "character": "RYUU:amused",
    "text": "Wow. A lost puppy, a nervous giant, and me. This day just got interesting."
  },
  {
    "chapter": 1,
    "scene": 5,
    "character": "NARRATION:neutral",
    "text": "Hoshi grins. Hajime stiffens. Megumi lingers nearby, silent but listening."
  },
  {
    "chapter": 1,
    "scene": 6,
    "character": "HOSHI:intrigued",
    "text": "Be honest, you guys feel it too, right? Like we’re not exactly ‘blend into the crowd’ material?"
  },
  {
    "chapter": 1,
    "scene": 7,
    "character": "HAJIME:defensive",
    "text": "…Yeah."
  },
  {
    "chapter": 1,
    "scene": 8,
    "character": "RYUU:bored",
    "text": "I don’t blend. I just choose when to stand out."
  },
  {
    "chapter": 1,
    "scene": 9,
    "character": "NARRATION:neutral",
    "text": "Megumi hesitates, then scribbles fast, holding up her notebook with shaking hands."
  },
  {
    "chapter": 1,
    "scene": 10,
    "character": "MEGUMI:neutral",
    "text": "“I… don’t fit either.”",
    "SpriteEffects": "Pulse"
  },
  {
    "chapter": 1,
    "scene": 11,
    "character": "NARRATION:neutral",
    "text": "[heartbeat] Four strangers. Same conclusion. None of you belong, and somehow, that connects you."
  },

  {
    "chapter": 2,
    "scene": 1,
    "character": "NARRATION:neutral",
    "text": "The courtyard bursts with club booths, loud pitches, and desperate recruitment energy."
  },
  {
    "chapter": 2,
    "scene": 2,
    "character": "NARRATION:neutral",
    "text": "One table stands different, quiet, precise, almost… intentional."
  },
  {
    "chapter": 2,
    "scene": 3,
    "character": "NARRATION:neutral",
    "text": "A girl waits there, composed, her gaze sharp beneath a perfect smile."
  },
  {
    "chapter": 2,
    "scene": 4,
    "character": "NAGISA:neutral",
    "text": "Looking for somewhere to belong?"
  },
  {
    "chapter": 2,
    "scene": 5,
    "character": "NARRATION:neutral",
    "text": "Her voice lands smoothly, like she practiced it until it was flawless."
  },
  {
    "chapter": 2,
    "scene": 6,
    "character": "HOSHI:chaotic",
    "text": "Please tell me this is cosplay. I will sell my soul immediately."
  },
  {
    "chapter": 2,
    "scene": 7,
    "character": "NAGISA:analytical",
    "text": "Of course. But we offer more than costumes, we offer <i>transformation</i>."
  },
  {
    "chapter": 2,
    "scene": 8,
    "character": "RYUU:amused",
    "text": "That sounds suspiciously like a pitch I shouldn’t trust."
  },
  {
    "chapter": 2,
    "scene": 9,
    "character": "NAGISA:neutral",
    "text": "And yet, you’re still listening."
  },
  {
    "chapter": 2,
    "scene": 10,
    "character": "NARRATION:neutral",
    "text": "She gestures to five empty chairs behind her."
  },
  {
    "chapter": 2,
    "scene": 11,
    "character": "NAGISA:analytical",
    "text": "Every group needs balance. Energy. Silence. Strength. Chaos… and something unpredictable."
  },
  {
    "chapter": 2,
    "scene": 12,
    "character": "NARRATION:neutral",
    "text": "[shadows] Her gaze moves across them, measured, precise, before settling on you."
  },
  {
    "chapter": 2,
    "scene": 13,
    "character": "NAGISA:analytical",
    "text": "You each bring something rare. That kind of potential shouldn’t go unused."
  },
  {
    "chapter": 2,
    "scene": 14,
    "character": "HAJIME:defensive",
    "text": "I… don’t think I belong in something like this."
  },
  {
    "chapter": 2,
    "scene": 15,
    "character": "NAGISA:neutral",
    "text": "You’d be surprised what you’re capable of."
  },
  {
    "chapter": 2,
    "scene": 16,
    "character": "NARRATION:neutral",
    "text": "Megumi sits first, hesitant. Hoshi drops in eagerly. Hajime follows. Ryuu joins with a shrug."
  },
  {
    "chapter": 2,
    "scene": 17,
    "character": "NARRATION:neutral",
    "text": "Four seats filled. One remains."
  },
  {
    "chapter": 2,
    "scene": 18,
    "character": "NAGISA:analytical",
    "text": "And you…"
  },
  {
    "chapter": 2,
    "scene": 19,
    "character": "NARRATION:neutral",
    "text": "She steps closer, studying you, not casually, but carefully."
  },
  {
    "chapter": 2,
    "scene": 20,
    "character": "NAGISA:analytical",
    "text": "<span style=\"color:#ffcc66\">You don’t follow patterns. That makes you interesting.</span>"
  },
  {
    "chapter": 2,
    "scene": 21,
    "character": "NAGISA:analytical",
    "text": "So tell me, {{user}}… will you take the last seat?"
  }
]
}