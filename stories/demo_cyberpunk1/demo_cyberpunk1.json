  "storyDialogue": [
    { "chapter": 0, "scene": 1, "character": "NARRATION", "text": "Get started! Use ‣ AUTO for auto scene change, LEFT/RIGHT icon for manual navigation, and toggle music/voice on the top bar. Explore character profiles via the menu." },
    { "chapter": 1, "scene": 1, "character": "BOSS", "text": "I want this <b style=\"color:#00ffcc;\">clean</b>, Runner." },
    { "chapter": 1, "scene": 2, "character": "RUNNER", "text": "Coordinates locked in. You’re getting close, but something’s off… Keep your eyes sharp." },
    { "chapter": 1, "scene": 3, "character": "RUNNER", "text": "Visual’s glitching… [shake] Runner, do you copy?" },
    { "chapter": 1, "scene": 4, "character": "EVA", "text": "[From the shadows] You shouldn’t have come here, <b style=\"color:#ff3366\">Corp dog</b>." },
    { "chapter": 1, "scene": 5, "character": "RUNNER", "effect": "ELECTROCUTED" },
    { "chapter": 1, "scene": 6, "character": "TIA", "text": "Eva, he’s collapsing." },
    { "chapter": 1, "scene": 7, "character": "EVA", "text": "Let him. Corporate trash like him don’t deserve a <i style=\"color:#888;\">quick end</i>." },
    { "chapter": 1, "scene": 8, "character": "RUNNER", "text": "[shake] [Glitching] Ru...ner?! Do you...copy?!" },
    { "chapter": 1, "scene": 9, "character": "TIA", "text": "Eva, he’s passed out. We should do something, right?" },
    { "chapter": 1, "scene": 10, "character": "EVA", "text": "Tie him up. We’re not playing nice with corporate assassins." },
    { "chapter": 1, "scene": 11, "character": "NARRATION", "text": "The signal fades into a hum of static as your consciousness slips away. <i style=\"color:red;\">[Signal lost]</i>" },

    { "chapter": 2, "scene": 1, "character": "TIA", "text": "Oh, you’re awake! I thought you'd sleep longer... after what we did. I’m Tia, by the way!" },
    { "chapter": 2, "scene": 2, "character": "EVA", "text": "[shake] Tia, don’t get friendly with him. He’s dangerous. We should’ve flatlined him already." },
    { "chapter": 2, "scene": 3, "character": "EVA", "text": "Corporate goons like him have one purpose—getting rid of us. Stop acting like he’s your pet." },
    { "chapter": 2, "scene": 4, "character": "TIA", "text": "But he doesn’t *seem* bad… I want to know why he came after us." },
    { "chapter": 2, "scene": 5, "character": "EVA", "text": "This isn’t a negotiation, Tia. You know how this ends." },
    { "chapter": 2, "scene": 6, "character": "TIA", "text": "Just one question... What’s your name? And why are you really here?" },
    { "chapter": 2, "scene": 7, "character": "NARRATION", "text": "The weight of your choices presses down. Will you embrace the <b style=\"color:#444;text-shadow:0 0 5px #000\">darkness</b>, or find another way?" }
  ]
